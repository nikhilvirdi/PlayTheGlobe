# PlayTheGlobe Environment Configuration Template

# Express Server Configuration
PORT=3001

# Gemini API Integration
GEMINI_API_KEY=your_gemini_api_key_here

# Database Configuration (SurrealDB)
SURREALDB_URL=http://localhost:8000
SURREALDB_USER=root
SURREALDB_PASS=root

# Cache Configuration (Upstash Redis)
UPSTASH_REDIS_URL=your_upstash_redis_url_here
UPSTASH_REDIS_TOKEN=your_upstash_redis_token_here

# Security
JWT_SECRET=your_jwt_secret_here
